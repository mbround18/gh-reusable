{
  "name": "gh-reusable",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace bootstrap for reusable actions.",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "test:coverage": "pnpm -r --if-present run test:coverage",
    "typecheck": "pnpm -r --if-present run typecheck",
    "generate:ci-skill": "tsx scripts/generate-ci-skill.ts"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.0"
  }
}
