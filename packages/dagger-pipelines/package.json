{
  "name": "@gh-reusable/dagger-pipelines",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable Dagger pipeline primitives for GitHub Action packaging.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./workflows": {
      "types": "./dist/workflows.d.ts",
      "import": "./dist/workflows.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dagger:ci": "node dist/cli.js ci",
    "dagger:build-and-push": "node dist/cli.js build-and-push",
    "dagger:workflow": "node dist/cli.js workflow"
  },
  "dependencies": {
    "@dagger.io/dagger": "catalog:",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
